---
// src/pages/academy/[id].astro
// Halaman Detail Kelas & Silabus

const { id } = Astro.params;

// Mock data (Nanti diganti fetch DB berdasarkan ID)
const course = {
  id: id,
  title: "Manajemen Aset Wakaf Produktif",
  description: "Pelatihan komprehensif mengelola aset wakaf (tanah, bangunan, uang) agar memberikan return produktif sesuai syariat dan regulasi BWI.",
  instructor: "Dr. Mayurida",
  duration: "4 Minggu",
  lessons_count: 12,
  image: "https://via.placeholder.com/800x400"
};

const syllabus = [
  { id: 1, title: "Pengantar Fiqih Wakaf Kontemporer", duration: "15 min" },
  { id: 2, title: "Regulasi BWI tentang Wakaf Uang", duration: "25 min" },
  { id: 3, title: "Studi Kasus: Wakaf Produktif Pertanian", duration: "40 min" }
];
---

<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{course.title} | INA</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen">
    <!-- Navbar placeholder -->
    <nav class="bg-white border-b border-slate-200 py-4 px-6">
        <a href="/academy" class="text-blue-600 hover:text-blue-800 font-medium font-medium flex items-center gap-2">
            ← Kembali ke Katalog
        </a>
    </nav>

    <main class="max-w-4xl mx-auto px-4 py-8">
        <!-- Hero Section -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-8">
            <img src={course.image} alt={course.title} class="w-full h-64 object-cover" />
            <div class="p-8">
                <h1 class="text-3xl font-bold text-slate-900 mb-4">{course.title}</h1>
                <p class="text-slate-600 text-lg mb-6">{course.description}</p>
                
                <div class="flex items-center gap-6 text-sm text-slate-500 mb-8 border-y border-slate-100 py-4">
                    <div><span class="font-semibold text-slate-900">Instruktur:</span> {course.instructor}</div>
                    <div><span class="font-semibold text-slate-900">Durasi:</span> {course.duration}</div>
                    <div><span class="font-semibold text-slate-900">Materi:</span> {course.lessons_count} Modul</div>
                </div>

                <a href={`/academy/learn/${id}`} class="inline-block w-full md:w-auto text-center bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-xl transition-colors">
                    Mulai Belajar Sekarang
                </a>
            </div>
        </div>

        <!-- Syllabus Section -->
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Silabus Pelatihan</h2>
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 divide-y divide-slate-100">
            {syllabus.map((item, index) => (
                <div class="p-4 flex items-center justify-between hover:bg-slate-50 transition-colors">
                    <div class="flex items-center gap-4">
                        <span class="flex items-center justify-center w-8 h-8 rounded-full bg-blue-100 text-blue-700 font-medium text-sm">
                            {index + 1}
                        </span>
                        <span class="font-medium text-slate-800">{item.title}</span>
                    </div>
                    <span class="text-sm text-slate-500">{item.duration}</span>
                </div>
            ))}
        </div>
    </main>
</body>
</html>
