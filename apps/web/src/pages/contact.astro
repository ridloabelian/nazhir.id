---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontak | nazhir.id" description="Kontak resmi nazhir.id dan Asosiasi Nazhir Indonesia.">
  <main class="max-w-3xl mx-auto px-6 py-20 space-y-8">
    <a href="/" class="text-emerald-400 text-sm font-bold">← Kembali</a>
    <h1 class="text-4xl font-black text-white">Kontak</h1>
    <div class="rounded-2xl border border-slate-800 bg-slate-950/40 p-6 space-y-4">
      <p class="text-slate-300">Untuk kerja sama, verifikasi lembaga, atau pertanyaan layanan nazhir.id:</p>
      <ul class="space-y-3 text-slate-300">
        <li><strong class="text-white">Organisasi:</strong> Asosiasi Nazhir Indonesia (ANI)</li>
        <li><strong class="text-white">Email:</strong> <a class="text-emerald-400" href="mailto:asosiasinazhir@gmail.com">asosiasinazhir@gmail.com</a></li>
        <li><strong class="text-white">Website:</strong> <a class="text-emerald-400" href="https://nazhir.id">https://nazhir.id</a></li>
      </ul>
    </div>
  </main>
</Layout>
