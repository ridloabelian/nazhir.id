---
import Layout from '../layouts/Layout.astro';
import AuthForm from '../components/AuthForm';
import { env } from 'cloudflare:workers';
import { getDB } from '../db';
import { getLucia } from '../auth';

// SSR: Cek apakah user sudah login
const isProd = import.meta.env.PROD;
const sql = getDB(env as any);
const lucia = getLucia(sql, isProd);

const sessionId = Astro.cookies.get(lucia.sessionCookieName)?.value;
let user = null;

if (sessionId) {
	try {
		const result = await lucia.validateSession(sessionId);
		user = result.user;
		if (user) {
			return Astro.redirect('/dashboard');
		}
	} catch (e) {
		// Sesi tidak valid/kedaluwarsa
	}
}
---

