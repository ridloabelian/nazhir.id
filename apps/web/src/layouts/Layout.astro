---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Dashboard Wakaf Nasional | Asosiasi Nazhir Indonesia",
	description = "Transformasi digital tata kelola wakaf menuju Smart Nazhir Ecosystem 2030. Laporan aset terintegrasi dan akuntabel."
} = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<script is:inline>
			(() => {
				const saved = localStorage.getItem('theme');
				const theme = saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				document.documentElement.dataset.theme = theme;
			})();
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="canonical" href={new URL(Astro.url.pathname, 'https://nazhir.id').toString()} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="nazhir.id" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={new URL(Astro.url.pathname, 'https://nazhir.id').toString()} />
		<meta name="twitter:card" content="summary" />
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'WebSite',
			name: 'nazhir.id',
			url: 'https://nazhir.id',
			publisher: {
				'@type': 'Organization',
				name: 'Asosiasi Nazhir Indonesia',
				email: 'asosiasinazhir@gmail.com',
				url: 'https://nazhir.id'
			}
		})} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
		
		<style>
			html,
			body {
				margin: 0;
				width: 100%;
				height: 100%;
				font-family: 'Plus Jakarta Sans', 'Outfit', sans-serif;
			}
		</style>
	</head>
	<body class="bg-slate-950 text-slate-100 min-h-screen selection:bg-emerald-500/30 selection:text-emerald-300 overflow-x-hidden">
		<!-- Background Glows -->
		<div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
			<div class="absolute -top-[40%] -left-[20%] w-[80%] h-[80%] rounded-full bg-emerald-950/30 blur-[150px] mix-blend-screen"></div>
			<div class="absolute -bottom-[40%] -right-[20%] w-[80%] h-[80%] rounded-full bg-teal-950/20 blur-[150px] mix-blend-screen"></div>
		</div>
		<div class="relative z-10 min-h-screen flex flex-col justify-between">
			<slot />
			<nav class="w-full border-t border-slate-900 px-6 py-4 text-center text-xs text-slate-500 bg-slate-950/40" aria-label="Informasi situs">
				<a class="hover:text-emerald-400 mx-2" href="/about">Tentang</a>
				<a class="hover:text-emerald-400 mx-2" href="/contact">Kontak</a>
				<a class="hover:text-emerald-400 mx-2" href="/privacy-policy">Privasi</a>
				<a class="hover:text-emerald-400 mx-2" href="/terms">Ketentuan</a>
			</nav>
		</div>
		<label class="sr-only" for="theme-select">Pilih tema</label>
		<select id="theme-select" class="theme-select" aria-label="Pilih tema tampilan">
			<option value="system">Ikuti perangkat</option>
			<option value="light">Terang</option>
			<option value="dark">Gelap</option>
		</select>
		<script is:inline>
			(() => {
				const select = document.getElementById('theme-select');
				const apply = (choice) => {
					const theme = choice === 'system'
						? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
						: choice;
					document.documentElement.dataset.theme = theme;
					if (choice === 'system') localStorage.removeItem('theme');
					else localStorage.setItem('theme', choice);
				};
				select.value = localStorage.getItem('theme') || 'system';
				select.addEventListener('change', () => apply(select.value));
				matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
					if (!localStorage.getItem('theme')) apply('system');
				});
			})();
		</script>
	</body>
</html>
