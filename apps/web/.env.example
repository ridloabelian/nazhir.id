# Supabase Database Configuration
# Ganti dengan connection string dari database Supabase Anda (Settings > Database)
DATABASE_URL="postgres://postgres:[YOUR_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://postgres:[YOUR_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Supabase Client Credentials (Optional if only using direct DB access via tRPC)
SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="[YOUR_ANON_KEY]"

# App Configuration
NODE_ENV="development"
PORT=4321
